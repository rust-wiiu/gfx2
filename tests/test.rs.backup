use gfd::{AttributeVar, Block, Buffer, Gfd, ShaderMode, VarType, VertexHeader};
use pretty_assertions::assert_eq;

#[test]
fn header_only() {
    let bytes = std::fs::read("tests/header-only.gsh").unwrap();

    let gfd = Gfd::parse(&bytes).unwrap();

    assert_eq!(
        gfd,
        Gfd {
            aligned: false,
            padding: 0,
            blocks: vec![]
        }
    );
}

#[test]
fn vertex_program() {
    let bytes = std::fs::read("tests/vertex-program.gsh").unwrap();

    let gfd = Gfd::parse(&bytes).unwrap();

    assert_eq!(
        gfd,
        Gfd {
            aligned: false,
            padding: 0,
            blocks: vec![Block::VertexProgram(vec![
                0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x80, 0x09, 0x20, 0x00, 0x00, 0x00, 0x00, 0x00,
                0x00, 0xA0, 0x3C, 0x20, 0x01, 0x00, 0x88, 0x06, 0x00, 0x94, 0x00, 0xC0, 0x00, 0x00,
                0x88, 0x06, 0x20, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
                0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
                0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
                0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
