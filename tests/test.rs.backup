#[test]
fn vertex_header() {
    let bytes = std::fs::read("tests/vertex-header.gsh").unwrap();

    let gfd = Gfd::parse(&bytes).unwrap();

    println!("{:?}", gfd);

    /*
     *
     */

    assert_eq!(
        gfd,
        Gfd {
            aligned: false,
            padding: 0,
            blocks: vec![Block::VertexHeader(VertexHeader {
                registers: [
                    259, 0, 0, 1, 4294967040, 4294967295, 4294967295, 4294967295, 4294967295,
                    4294967295, 4294967295, 4294967295, 4294967295, 4294967295, 0, 4294967292, 2,
                    1, 0, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255,
                    255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255, 255,
                    0, 14, 16
                ],
                program_size: 280,
                shader_mode: ShaderMode::UniformRegister,
                uniform_blocks: vec![],
                uniform_vars: vec![],
                initial_values: vec![],
                loop_vars: vec![],
                sampler_vars: vec![],
                attrib_vars: vec![
                    AttributeVar {
                        name: "in_color".to_string(),
                        ty: VarType::Float4,
                        count: 0,
                        location: 1
                    },
                    AttributeVar {
                        name: "in_position".to_string(),
                        ty: VarType::Float3,
                        count: 0,
                        location: 0
                    }
                ],
                ring_item_size: 0,
                has_stream_out: 0,
                stream_out_stride: [0, 0, 0, 0],
                buffer: Buffer {
                    flags: 0,
                    elem_size: 0,
                    len: 0,
                    ptr: 0
                }
            })]
        }
    );
}
